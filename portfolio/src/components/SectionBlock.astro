---
interface Props {
  id: string
  title: string
  kicker?: string
  class?: string
}

const { id, title, kicker, class: className = '' } = Astro.props
---

<section id={id} class:list={['section-block', className]}>
  <div class="section-head">
    {kicker && <p class="eyebrow">{kicker}</p>}
    <h2 class="section-title">{title}</h2>
  </div>

  <div class="section-body">
    <slot />
  </div>
</section>
