---
const INITIATIVES = [
  {
    label: 'Ways of working',
    title: 'UES Standardization',
    summary:
      'Work focused on defining a common base for projects across the department: useful minimum documentation, frontend-backend contracts, templates, CI/CD, and context that remains readable for agents too.',
    detail:
      'The goal was not to add process for the sake of it, but to remove friction from onboarding, handover, code review, and deployment without burdening teams with unnecessary bureaucracy.'
  },
  {
    label: 'Technical adoption',
    title: 'Applied AI in the engineering workflow',
    summary:
      'Research and synthesis around how to integrate assistants, agents, MCPs, skills, and new working modes into real software development.',
    detail:
      'I am especially interested in the moment a tool stops being a demo and becomes part of a clear operating model, with context, guardrails, and human review.'
  }
]
---

<div class="initiative-list">
  {
    INITIATIVES.map((initiative) => (
      <article class="initiative-entry">
        <p class="initiative-label">{initiative.label}</p>
        <h3>{initiative.title}</h3>
        <p>{initiative.summary}</p>
        <p>{initiative.detail}</p>
      </article>
    ))
  }
</div>

<style>
  .initiative-list {
    display: grid;
    gap: 28px;
  }

  .initiative-entry {
    display: grid;
    gap: 4px;
  }

  .initiative-label {
    font-size: 12px;
    color: var(--soft-ink);
  }

  .initiative-entry h3 {
    font-size: 16px;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: 0;
    color: var(--ink-deep);
  }

  .initiative-entry p {
    font-size: 14px;
    line-height: 1.75;
    color: var(--muted-ink);
  }

  .initiative-entry h3,
  .initiative-label {
    margin: 0;
  }
</style>
