---
import type { Locale } from '../data/portfolioContent'

interface Props {
  locale: Locale
  meta: string
  switchHref: string
}

const { locale, meta, switchHref } = Astro.props
const currentLocale = locale.toUpperCase()
const alternateLocale = locale === 'en' ? 'ES' : 'EN'
const switchLabel = locale === 'en' ? 'Language' : 'Idioma'
---

<header class="topbar">
  <span class="topbar-meta">{meta}</span>

  <nav class="topbar-locale" aria-label={switchLabel}>
    <span class="topbar-locale-current">{currentLocale}</span>
    <span aria-hidden="true">/</span>
    <a href={switchHref}>{alternateLocale}</a>
  </nav>
</header>

<style>
  .topbar {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 8px 18px;
    margin-bottom: 34px;
  }

  .topbar-meta {
    font-size: 13px;
    line-height: 1.6;
    color: var(--muted-ink);
  }

  .topbar-locale {
    display: inline-flex;
    align-items: baseline;
    gap: 7px;
    font-size: 13px;
    line-height: 1.6;
    color: var(--muted-ink);
  }

  .topbar-locale-current {
    color: var(--ink);
  }

  .topbar-locale a {
    color: var(--muted-ink);
    text-decoration: none;
  }

  .topbar-locale a:hover,
  .topbar-locale a:focus-visible {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    outline: none;
  }

  @media (max-width: 640px) {
    .topbar {
      margin-bottom: 26px;
    }
  }
</style>
