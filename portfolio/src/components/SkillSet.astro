---
const GROUPS = [
  {
    title: 'Interfaces',
    description: 'Clear interfaces with good hierarchy, structure, and attention to detail.',
    items: ['React', 'TypeScript', 'JavaScript', 'HTML', 'CSS', 'Tailwind', 'Redux']
  },
  {
    title: 'Systems',
    description: 'Application logic, APIs, services, and backend component design.',
    items: ['Node.js', 'Express', 'Python', 'Flask', 'Java', 'REST API']
  },
  {
    title: 'Data and AI',
    description: 'Data modeling, persistence, and the technical base needed to explore applied AI.',
    items: ['PostgreSQL', 'MySQL', 'MongoDB']
  },
  {
    title: 'Infra and tooling',
    description: 'Working environment, testing, deployment, and tools for solving problems with sound judgment.',
    items: ['Docker', 'Jest', 'GitHub', 'Linux', 'AWS', 'Postman']
  }
]
---

<div class="stack-flow">
  {
    GROUPS.map((group) => (
      <article class="stack-item">
        <p class="stack-label">{group.title}</p>
        <p class="stack-description">{group.description}</p>
        <p class="stack-items">{group.items.join(' / ')}</p>
      </article>
    ))
  }
</div>

<style>
  .stack-flow {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px 36px;
  }

  .stack-item {
    display: grid;
    gap: 6px;
  }

  .stack-label {
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono',
      'Courier New', monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .stack-description {
    max-width: none;
    font-size: 15.5px;
    line-height: 1.66;
    color: var(--muted-ink);
  }

  .stack-items {
    max-width: none;
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink);
  }

  @media (max-width: 900px) {
    .stack-flow {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
</style>
