---
interface Props {
  kind: string
  title: string
  organization: string
  description: string
  period: string
}

const { kind, title, organization, description, period } = Astro.props
---

<article class="track-item">
  <p class="track-meta">
    <span class="track-kind">{kind}</span>
    <time class="track-period">{period}</time>
  </p>

  <h3>{title}</h3>
  <p class="track-organization">{organization}</p>
  <p class="track-description">{description}</p>
</article>

<style>
  .track-item {
    display: grid;
    gap: 4px;
  }

  .track-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 10px;
  }

  .track-kind {
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
    color: var(--soft-ink);
  }

  .track-period {
    font-size: 13px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--soft-ink);
  }

  .track-item h3 {
    font-size: 15px;
    font-weight: 500;
    line-height: 1.6;
    letter-spacing: 0;
  }

  .track-organization {
    font-size: 14px;
    line-height: 1.65;
    color: var(--ink);
  }

  .track-description {
    font-size: 15px;
    line-height: 1.7;
    color: var(--muted-ink);
  }
</style>
