---
interface Props {
  kind: string
  title: string
  organization: string
  description: string
  period: string
}

const { kind, title, organization, description, period } = Astro.props
---

<article class="track-item">
  <p class="track-meta">
    <span class="track-kind">{kind}</span>
    <time class="track-period">{period}</time>
  </p>

  <h3>{title}</h3>
  <p class="track-organization">{organization}</p>
  <p class="track-description">{description}</p>
</article>

<style>
  .track-item {
    display: grid;
    gap: 0;
  }

  .track-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 10px;
  }

  .track-kind {
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
    color: var(--soft-ink);
  }

  .track-period {
    font-size: 12px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--soft-ink);
  }

  .track-item h3 {
    font-size: 16px;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: 0;
    color: var(--ink-deep);
    margin-top: 5px;
  }

  .track-organization {
    font-size: 12px;
    line-height: 1.6;
    color: var(--soft-ink);
    font-style: italic;
    margin-top: 2px;
  }

  .track-description {
    font-size: 14px;
    line-height: 1.75;
    color: var(--muted-ink);
    margin-top: 8px;
  }
</style>
