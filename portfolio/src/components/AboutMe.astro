---
interface Props {
  paragraphs: string[]
}

const { paragraphs } = Astro.props
---

<div class="about-copy">
  {paragraphs.map((paragraph) => <p>{paragraph}</p>)}
</div>

<style>
  .about-copy {
    display: grid;
    gap: 10px;
  }

  .about-copy p {
    font-size: 14px;
    line-height: 1.75;
    color: var(--muted-ink);
  }
</style>
