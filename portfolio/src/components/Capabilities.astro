---
import type { CapabilityItem } from '../data/portfolioContent'

interface Props {
  items: CapabilityItem[]
}

const { items } = Astro.props
---

<div class="capability-list">
  {
    items.map((capability) => (
      <article class="capability-entry">
        <h3>{capability.title}</h3>
        <p>{capability.detail}</p>
      </article>
    ))
  }
</div>

<style>
  .capability-list {
    display: grid;
    gap: 18px;
  }

  .capability-entry {
    display: grid;
    gap: 3px;
  }

  .capability-entry h3 {
    font-size: 15px;
    font-weight: 500;
    line-height: 1.6;
    letter-spacing: 0;
  }

  .capability-entry p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--muted-ink);
  }
</style>
