---
import LinkButton from './LinkButton.astro'

const PROJECTS = [
  {
    label: 'Infraestructura de agentes',
    title: 'Agent Runtime',
    summary:
      'Capa compartida de tooling para que los compañeros adopten agentes sin configurar nada desde cero. Empaqueta MCPs y skills como abstracciones listas para usar: cada departamento trabaja con su propio conjunto de herramientas, convenciones y nombres de recursos, sin que el setup dependa de cada persona.',
    role: 'Arquitectura de tooling',
    stack: 'MCP, Python, shell scripts y wrappers multiagente',
    focus: 'Abstracciones reutilizables, convenciones por departamento y adopción sin fricción'
  },
  {
    label: 'Sistema privado',
    title: 'Memoria Operativa',
    summary:
      'Sistema local-first para trabajar con agentes sobre proyectos, tareas y contexto persistente. Une memoria viva, búsqueda semántica, organización ligera y tooling MCP para reducir la carga de contexto entre sesiones.',
    role: 'Arquitectura + full stack',
    stack: 'FastAPI, Next.js, Postgres, pgvector, Ollama y MCP',
    focus: 'Memoria de proyecto, recuperación semántica y herramientas para agentes',
    links: [{ label: 'Código', href: 'https://github.com/zvizzct/organizacion' }]
  },
  {
    label: 'Pipeline interna + LLM',
    title: 'Catalogo UES',
    summary:
      'Sistema interno para UES orientado a convertir proyectos de GitLab en un catalogo consultable. La parte importante fue plantear la pipeline completa: scrapeo, enriquecimiento con LLM, clasificacion, API y una interfaz desde la que recuperar contexto tecnico sin revisar repositorio por repositorio.',
    role: 'Pipeline de datos + producto',
    stack: 'Python, GitLab API, Spring Boot, MySQL, Next.js y Docker',
    focus: 'Extraccion automatizada, normalizacion de metadata y acceso rapido al conocimiento'
  },
  {
    label: 'iOS nativo',
    title: 'Closet Native',
    summary:
      'App de armario personal en SwiftUI. Usa visión por LLM para identificar y catalogar prendas a partir de fotos, genera combinaciones de outfit con IA según el contexto del día, y organiza el uso a través de un calendario. Incluye comunidad para compartir looks y modelo de suscripción.',
    role: 'iOS + producto',
    stack: 'SwiftUI, async/await, LLM vision, Supabase y arquitectura modular',
    focus: 'Visión aplicada, generación de outfits y experiencia nativa',
    links: [{ label: 'Código', href: 'https://github.com/zvizzct/outfit-ios' }]
  },
  {
    label: 'Biblioteca digital',
    title: 'El Quiosco',
    summary:
      'Biblioteca EPUB para hacer el acceso a la cultura más directo. Sin plataformas intermedias ni formatos propietarios: cualquiera puede tener su catálogo personal consultable desde el navegador, con búsqueda, organización y lectura integradas.',
    role: 'Frontend + backend',
    stack: 'React, Tailwind, Node.js, Express y PostgreSQL',
    focus: 'Acceso abierto, catálogo personal y experiencia de lectura sin fricción',
    links: [{ label: 'Código', href: 'https://github.com/zvizzct/backend-epub-library' }]
  }
]
---

<div class="project-list">
  {
    PROJECTS.map((project) => (
      <article class="project-entry">
        <div class="project-head">
          <p class="project-meta-line">
            <span>{project.label}</span>
            <span>{project.role}</span>
          </p>
          <h3>{project.title}</h3>
        </div>

        <p class="project-summary">{project.summary}</p>

        <p class="project-detail">
          <span>Stack</span>
          {project.stack}
        </p>

        <p class="project-detail">
          <span>Foco</span>
          {project.focus}
        </p>

        {project.links && (
          <div class="project-actions">
            {
              project.links.map((link, index) => (
                <LinkButton href={link.href} variant={index === 0 ? 'primary' : 'secondary'}>
                  {link.label}
                </LinkButton>
              ))
            }
          </div>
        )}
      </article>
    ))
  }
</div>

<style>
  .project-list {
    display: grid;
    gap: 24px;
  }

  .project-entry {
    display: grid;
    gap: 5px;
  }

  .project-head {
    display: grid;
    gap: 2px;
  }

  .project-meta-line {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 10px;
    font-size: 13px;
    line-height: 1.6;
    letter-spacing: 0;
    color: var(--soft-ink);
  }

  .project-meta-line span:first-child {
    color: var(--muted-ink);
  }

  .project-head h3 {
    font-size: 15px;
    font-weight: 500;
    line-height: 1.6;
    letter-spacing: 0;
  }

  .project-summary {
    font-size: 15px;
    line-height: 1.7;
    color: var(--muted-ink);
  }

  .project-detail {
    font-size: 14px;
    line-height: 1.7;
    color: var(--muted-ink);
  }

  .project-detail span {
    color: var(--ink);
  }

  .project-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    margin-top: 2px;
  }
</style>
