---
import LinkButton from './LinkButton.astro'
import type { PortfolioContent, ProjectItem } from '../data/portfolioContent'

interface Props {
  projects: ProjectItem[]
  labels: PortfolioContent['projectLabels']
}

const { projects, labels } = Astro.props
---

<div class="project-list">
  {
    projects.map((project) => (
      <article class="project-entry">
        <div class="project-head">
          <p class="project-meta-line">
            <span>{project.label}</span>
            <span>{labels.role}: {project.role}</span>
          </p>
          <h3>{project.title}</h3>
        </div>

        <p class="project-summary">{project.summary}</p>

        <div class="project-details">
          <p class="project-detail"><span>{labels.contribution}</span>{project.contribution}</p>
          <p class="project-detail"><span>{labels.impact}</span>{project.impact}</p>
          <p class="project-detail"><span>{labels.stack}</span>{project.stack}</p>
        </div>

        {project.links && (
          <div class="project-actions">
            {
              project.links.map((link, index) => (
                <LinkButton href={link.href} variant={index === 0 ? 'primary' : 'secondary'}>
                  {link.label}
                </LinkButton>
              ))
            }
          </div>
        )}
      </article>
    ))
  }
</div>

<style>
  .project-list {
    display: grid;
    gap: 28px;
  }

  .project-entry {
    display: grid;
    gap: 0;
  }

  .project-head {
    display: grid;
    gap: 5px;
    margin-bottom: 10px;
  }

  .project-meta-line {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 10px;
    font-size: 12px;
    line-height: 1.6;
    letter-spacing: 0;
    color: var(--soft-ink);
  }

  .project-meta-line span:first-child {
    color: var(--soft-ink);
  }

  .project-head h3 {
    font-size: 16px;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: 0;
    color: var(--ink-deep);
  }

  .project-summary {
    font-size: 13px;
    line-height: 1.75;
    color: var(--muted-ink);
    margin-bottom: 10px;
  }

  .project-details {
    display: grid;
    gap: 4px;
    padding-top: 10px;
    border-top: 1px solid rgba(30, 30, 28, 0.08);
  }

  .project-detail {
    font-size: 13px;
    line-height: 1.65;
    color: var(--muted-ink);
  }

  .project-detail span {
    font-weight: 500;
    color: var(--ink);
    margin-right: 6px;
  }

  .project-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    margin-top: 12px;
  }
</style>
