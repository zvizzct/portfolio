---
import LinkButton from './LinkButton.astro'
import type { ProjectItem } from '../data/portfolioContent'

interface Props {
  projects: ProjectItem[]
}

const { projects } = Astro.props
---

<div class="project-list">
  {
    projects.map((project) => (
      <article class="project-entry">
        <div class="project-head">
          <p class="project-meta-line">
            <span>{project.label}</span>
            <span>{project.role}</span>
          </p>
          <h3>{project.title}</h3>
        </div>

        <p class="project-summary">{project.summary}</p>

        <p class="project-detail">
          <span>Stack</span>
          {project.stack}
        </p>

        <p class="project-detail">
          <span>Contribution</span>
          {project.contribution}
        </p>

        <p class="project-detail">
          <span>Outcome</span>
          {project.impact}
        </p>

        {project.links && (
          <div class="project-actions">
            {
              project.links.map((link, index) => (
                <LinkButton href={link.href} variant={index === 0 ? 'primary' : 'secondary'}>
                  {link.label}
                </LinkButton>
              ))
            }
          </div>
        )}
      </article>
    ))
  }
</div>

<style>
  .project-list {
    display: grid;
    gap: 24px;
  }

  .project-entry {
    display: grid;
    gap: 5px;
  }

  .project-head {
    display: grid;
    gap: 2px;
  }

  .project-meta-line {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 10px;
    font-size: 13px;
    line-height: 1.6;
    letter-spacing: 0;
    color: var(--soft-ink);
  }

  .project-meta-line span:first-child {
    color: var(--muted-ink);
  }

  .project-head h3 {
    font-size: 15px;
    font-weight: 500;
    line-height: 1.6;
    letter-spacing: 0;
  }

  .project-summary {
    font-size: 15px;
    line-height: 1.7;
    color: var(--muted-ink);
  }

  .project-detail {
    font-size: 14px;
    line-height: 1.7;
    color: var(--muted-ink);
  }

  .project-detail span {
    color: var(--ink);
  }

  .project-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    margin-top: 2px;
  }
</style>
