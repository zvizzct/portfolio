---
import ExperienceItem from './ExperienceItem.astro'
import type { ExperienceItemData } from '../data/portfolioContent'

interface Props {
  items: ExperienceItemData[]
}

const { items } = Astro.props
---

<div class="studies-list">
  {items.map((entry) => <ExperienceItem {...entry} />)}
</div>

<style>
  .studies-list {
    display: grid;
    gap: 28px;
  }
</style>
