---
import ExperienceItem from './ExperienceItem.astro'

const STUDIES = [
  {
    kind: 'Education',
    title: 'Computer Engineering',
    organization: 'Universitat Pompeu Fabra',
    period: 'Completed',
    description:
      'Training focused on software engineering, analysis, architecture, and systems development.'
  },
  {
    kind: 'Education',
    title: 'Advanced Vocational Diploma in Web Development',
    organization: 'Earlier technical training',
    period: 'Earlier stage',
    description:
      'Hands-on foundation in frontend, backend, and development fundamentals before going deeper into software engineering.'
  }
]
---

<div class="studies-list">
  {STUDIES.map((entry) => <ExperienceItem {...entry} />)}
</div>

<style>
  .studies-list {
    display: grid;
    gap: 28px;
  }
</style>
