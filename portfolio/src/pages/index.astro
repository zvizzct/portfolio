---
import Layout from '../layouts/Layout.astro'
import AboutMe from '../components/AboutMe.astro'
import Capabilities from '../components/Capabilities.astro'
import Experience from '../components/Experience.astro'
import LinkButton from '../components/LinkButton.astro'
import Projects from '../components/Projects.astro'
import SectionBlock from '../components/SectionBlock.astro'
import Studies from '../components/Studies.astro'
---

<Layout
  title="Víctor Puerta | Portfolio"
  description="Portfolio of Víctor Puerta, focused on full-stack development, automation, internal tools, and applied AI."
>
  <main class="site-main" id="main-content">
    <section class="hero" id="home">
      <h1 class="hero-title">Víctor Puerta</h1>

      <p class="hero-title-note">Full-stack developer with a focus on automation, internal tools, and applied AI.</p>

      <p class="hero-lede">
        I design and build full-stack software for teams, from interfaces and
        APIs to workflows and internal systems that reduce manual work and make
        it easier to operate with context.
      </p>

      <p class="hero-support">
        My background is full-stack development across frontend, backend, APIs,
        and product work, but over the last few years I have moved closer to
        automation, internal tools, LLM-powered workflows, and the practical
        adoption of AI in engineering teams.
      </p>

      <div class="link-list">
        <LinkButton href="mailto:victor.puerta2298@gmail.com">email</LinkButton>
        <LinkButton
          href="https://www.linkedin.com/in/victor-puerta-zvizzct/"
          variant="secondary"
        >
          linkedin
        </LinkButton>
        <LinkButton href="https://github.com/zvizzct" variant="secondary">
          github
        </LinkButton>
      </div>
    </section>

    <SectionBlock
      id="what-i-do"
      title="What I work on"
      kicker="Where I usually contribute"
    >
      <Capabilities />
    </SectionBlock>

    <SectionBlock
      id="experience"
      title="Experience"
      kicker="Professional background"
    >
      <Experience />
    </SectionBlock>

    <SectionBlock
      id="projects"
      title="Projects"
      kicker="Systems, tooling, and product"
    >
      <Projects />
    </SectionBlock>

    <SectionBlock
      id="education"
      title="Education"
      kicker="Academic and technical foundation"
    >
      <Studies />
    </SectionBlock>

    <SectionBlock
      id="how-i-work"
      title="How I work"
      kicker="Engineering judgment and working style"
    >
      <AboutMe />
    </SectionBlock>

    <section class="contact-note" id="contact">
      <div class="contact-copy">
        <p class="eyebrow contact-eyebrow">contact</p>
        <h2>Get in touch</h2>
      </div>

      <div class="contact-actions">
        <LinkButton href="mailto:victor.puerta2298@gmail.com">
          email
        </LinkButton>
        <LinkButton
          href="https://www.linkedin.com/in/victor-puerta-zvizzct/"
          variant="secondary"
        >
          linkedin
        </LinkButton>
        <LinkButton href="https://github.com/zvizzct" variant="secondary">
          github
        </LinkButton>
      </div>
    </section>
  </main>
</Layout>

<style>
  .hero {
    display: grid;
    gap: 12px;
    margin-bottom: 56px;
  }

  .hero-title {
    font-size: 24px;
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: 0;
  }

  .hero-title-note {
    color: var(--ink);
    font-size: 14px;
    font-weight: 400;
    line-height: 1.7;
    letter-spacing: 0;
  }

  .hero-lede {
    font-size: 15px;
    line-height: 1.7;
    color: var(--muted-ink);
    max-width: 60ch;
  }

  .hero-support {
    font-size: 15px;
    line-height: 1.7;
    color: var(--muted-ink);
    max-width: 60ch;
  }

  .contact-note {
    display: block;
    margin-top: 42px;
    color: var(--ink);
  }

  .contact-copy {
    display: grid;
    gap: 8px;
  }

  .contact-eyebrow {
    color: var(--soft-ink);
  }

  .contact-copy h2 {
    font-size: 15px;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: 0;
  }

  .contact-copy p:last-child {
    font-size: 15px;
    line-height: 1.7;
    color: var(--muted-ink);
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    margin-top: 10px;
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: 28px;
    }
  }

  @media (max-width: 640px) {
    .hero {
      margin-bottom: 42px;
    }

    .hero-title {
      font-size: 20px;
    }

    .hero-title-note {
      font-size: 14px;
    }

    .hero-lede {
      font-size: 14px;
    }

    .hero-support {
      font-size: 14px;
    }

    .contact-copy h2 {
      font-size: 17px;
    }
  }
</style>
