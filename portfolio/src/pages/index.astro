---
import Layout from '../layouts/Layout.astro'
import AboutMe from '../components/AboutMe.astro'
import Experience from '../components/Experience.astro'
import LinkButton from '../components/LinkButton.astro'
import Projects from '../components/Projects.astro'
import SectionBlock from '../components/SectionBlock.astro'
import Studies from '../components/Studies.astro'
---

<Layout
  title="Víctor Puerta | Portfolio"
  description="Portfolio de Víctor Puerta, con foco en sistemas, automatización, IA aplicada y resolución de problemas."
>
  <main class="site-main" id="main-content">
    <section class="hero" id="inicio">
      <h1 class="hero-title">Víctor Puerta</h1>

      <p class="hero-title-note">Sistemas internos, tooling de ingeniería e IA aplicada.</p>

      <p class="hero-lede">
        Diseño y construyo software para equipos: pipelines, herramientas y
        capas de trabajo que hacen más fácil operar, documentar y escalar
        sistemas con criterio.
      </p>

      <p class="hero-support">
        Me interesa especialmente el punto donde producto, sistemas y adopción
        real de IA dejan de ir por separado y empiezan a reforzarse entre sí.
      </p>

      <div class="link-list">
        <LinkButton href="mailto:victor.puerta2298@gmail.com">email</LinkButton>
        <LinkButton
          href="https://www.linkedin.com/in/victor-puerta-zvizzct/"
          variant="secondary"
        >
          linkedin
        </LinkButton>
        <LinkButton href="https://github.com/zvizzct" variant="secondary">
          github
        </LinkButton>
      </div>
    </section>

    <SectionBlock
      id="experiencia"
      title="Experiencia"
      kicker="Recorrido profesional"
    >
      <Experience />
    </SectionBlock>

    <SectionBlock
      id="proyectos"
      title="Proyectos"
      kicker="Sistemas, tooling y producto"
    >
      <Projects />
    </SectionBlock>

    <SectionBlock
      id="estudios"
      title="Estudios"
      kicker="Base académica y técnica"
    >
      <Studies />
    </SectionBlock>

    <SectionBlock
      id="sobre-mi"
      title="Cómo trabajo"
      kicker="Criterio técnico y forma de trabajo"
    >
      <AboutMe />
    </SectionBlock>

    <section class="contact-note" id="contacto">
      <div class="contact-copy">
        <p class="eyebrow contact-eyebrow">final</p>
        <h2>Contacto</h2>
      </div>

      <div class="contact-actions">
        <LinkButton href="mailto:victor.puerta2298@gmail.com">
          email
        </LinkButton>
        <LinkButton
          href="https://www.linkedin.com/in/victor-puerta-zvizzct/"
          variant="secondary"
        >
          linkedin
        </LinkButton>
        <LinkButton href="https://github.com/zvizzct" variant="secondary">
          github
        </LinkButton>
      </div>
    </section>
  </main>
</Layout>

<style>
  .hero {
    display: grid;
    gap: 12px;
    margin-bottom: 56px;
  }

  .hero-title {
    font-size: 24px;
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: 0;
  }

  .hero-title-note {
    color: var(--ink);
    font-size: 14px;
    font-weight: 400;
    line-height: 1.7;
    letter-spacing: 0;
  }

  .hero-lede {
    font-size: 15px;
    line-height: 1.7;
    color: var(--muted-ink);
    max-width: 60ch;
  }

  .hero-support {
    font-size: 15px;
    line-height: 1.7;
    color: var(--muted-ink);
    max-width: 60ch;
  }

  .contact-note {
    display: block;
    margin-top: 42px;
    color: var(--ink);
  }

  .contact-copy {
    display: grid;
    gap: 8px;
  }

  .contact-eyebrow {
    color: var(--soft-ink);
  }

  .contact-copy h2 {
    font-size: 15px;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: 0;
  }

  .contact-copy p:last-child {
    font-size: 15px;
    line-height: 1.7;
    color: var(--muted-ink);
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    margin-top: 10px;
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: 28px;
    }
  }

  @media (max-width: 640px) {
    .hero {
      margin-bottom: 42px;
    }

    .hero-title {
      font-size: 20px;
    }

    .hero-title-note {
      font-size: 14px;
    }

    .hero-lede {
      font-size: 14px;
    }

    .hero-support {
      font-size: 14px;
    }

    .contact-copy h2 {
      font-size: 17px;
    }
  }
</style>
