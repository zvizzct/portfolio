---
import Layout from '../layouts/Layout.astro'
import AboutMe from '../components/AboutMe.astro'
import Experience from '../components/Experience.astro'
import LinkButton from '../components/LinkButton.astro'
import Projects from '../components/Projects.astro'
import SectionBlock from '../components/SectionBlock.astro'
import Studies from '../components/Studies.astro'
---

<Layout
  title="Víctor Puerta | Portfolio"
  description="Portfolio de Víctor Puerta, con foco en sistemas, automatizacion, IA aplicada y resolucion de problemas."
>
  <main class="site-main">
    <section class="hero" id="inicio">
      <h1 class="hero-title">Víctor Puerta</h1>

      <p class="hero-title-note">Ingeniería de software, sistemas e IA.</p>

      <p class="hero-lede">
        Construyo software y también el marco que lo rodea: documentación
        accionable, tooling útil y decisiones que aguantan cuando el equipo
        crece.
      </p>

      <div class="link-list">
        <LinkButton href="mailto:victor.puerta2298@gmail.com">email</LinkButton>
        <LinkButton
          href="https://www.linkedin.com/in/victor-puerta-zvizzct/"
          variant="secondary"
        >
          linkedin
        </LinkButton>
        <LinkButton href="https://github.com/zvizzct" variant="secondary">
          github
        </LinkButton>
      </div>

      <ul class="hero-notes">
        <li class="hero-note-row">
          <span class="eyebrow">Ahora:</span>
          <p>Eurecat, pipelines, sistemas internos y tooling de ingeniería.</p>
        </li>
        <li class="hero-note-row">
          <span class="eyebrow">Siguiente:</span>
          <p>Un equipo donde diseñar y construir formen parte del mismo trabajo.</p>
        </li>
      </ul>
    </section>

    <SectionBlock
      id="experiencia"
      title="Experiencia"
      kicker="Recorrido profesional"
    >
      <Experience />
    </SectionBlock>

    <SectionBlock
      id="proyectos"
      title="Proyectos"
      kicker="Sistemas, tooling y producto"
    >
      <Projects />
    </SectionBlock>

    <SectionBlock
      id="estudios"
      title="Estudios"
      kicker="Base académica y técnica"
    >
      <Studies />
    </SectionBlock>

    <SectionBlock
      id="sobre-mi"
      title="Perfil"
      kicker="Qué busco y cómo trabajo"
    >
      <AboutMe />
    </SectionBlock>

    <section class="contact-note" id="contacto">
      <div class="contact-copy">
        <p class="eyebrow contact-eyebrow">final</p>
        <h2>Contacto</h2>
      </div>

      <div class="contact-actions">
        <LinkButton href="mailto:victor.puerta2298@gmail.com">
          email
        </LinkButton>
        <LinkButton
          href="https://www.linkedin.com/in/victor-puerta-zvizzct/"
          variant="secondary"
        >
          linkedin
        </LinkButton>
        <LinkButton href="https://github.com/zvizzct" variant="secondary">
          github
        </LinkButton>
      </div>
    </section>
  </main>
</Layout>

<style>
  .hero {
    display: grid;
    gap: 12px;
    margin-bottom: 56px;
  }

  .hero-notes {
    display: grid;
    gap: 8px;
    list-style: none;
    margin: 12px 0 0;
  }

  .hero-note-row {
    display: block;
  }

  .hero-note-row .eyebrow {
    display: inline;
    color: var(--ink);
  }

  .hero-note-row p {
    display: inline;
    margin-left: 8px;
    font-size: 14px;
    line-height: 1.7;
    color: var(--muted-ink);
  }

  .hero-title {
    font-size: 24px;
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: 0;
  }

  .hero-title-note {
    color: var(--ink);
    font-size: 14px;
    font-weight: 400;
    line-height: 1.7;
    letter-spacing: 0;
  }

  .hero-lede {
    font-size: 15px;
    line-height: 1.7;
    color: var(--muted-ink);
    max-width: 62ch;
  }

  .contact-note {
    display: block;
    margin-top: 42px;
    color: var(--ink);
  }

  .contact-copy {
    display: grid;
    gap: 8px;
  }

  .contact-eyebrow {
    color: var(--soft-ink);
  }

  .contact-copy h2 {
    font-size: 15px;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: 0;
  }

  .contact-copy p:last-child {
    font-size: 15px;
    line-height: 1.7;
    color: var(--muted-ink);
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    margin-top: 10px;
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: 28px;
    }
  }

  @media (max-width: 640px) {
    .hero {
      margin-bottom: 42px;
    }

    .hero-title {
      font-size: 20px;
    }

    .hero-title-note {
      font-size: 14px;
    }

    .hero-lede {
      font-size: 14px;
    }

    .contact-copy h2 {
      font-size: 17px;
    }
  }
</style>
