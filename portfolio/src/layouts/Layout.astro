---
import Header from '../components/Header.astro'
import type { Locale } from '../data/portfolioContent'

interface Props {
  title: string
  description: string
  lang: Locale
  skipLinkLabel: string
  headerMeta: string
  switchHref: string
}

const { description, title, lang, skipLinkLabel, headerMeta, switchHref } = Astro.props
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">{skipLinkLabel}</a>
    <div class="page-frame">
      <Header locale={lang} meta={headerMeta} switchHref={switchHref} />
      <slot />
    </div>
  </body>
</html>

<style is:global>
  :root {
    --canvas: #c9c9c7;
    --paper: #f4f4f2;
    --paper-alt: #eeeeed;
    --ink: #1e1e1c;
    --ink-deep: #111110;
    --accent: #334454;
    --muted-ink: rgba(30, 30, 28, 0.72);
    --soft-ink: rgba(30, 30, 28, 0.64);
    --rule: 1px;
    --rule-thin: 1px;
    color-scheme: light;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--canvas);
    color: var(--ink);
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
      'Liberation Mono', 'Courier New', monospace;
    letter-spacing: 0.012em;
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--canvas);
    color: var(--ink);
  }

  .skip-link {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 10;
    padding: 8px 10px;
    background: var(--paper);
    border: 1px solid rgba(30, 30, 28, 0.2);
    color: var(--ink);
    transform: translateY(-140%);
    transition: transform 150ms ease;
  }

  .skip-link:focus-visible {
    transform: translateY(0);
    outline: 1px solid var(--accent);
    outline-offset: 2px;
  }

  ::selection {
    background: rgba(74, 92, 110, 0.18);
    color: var(--ink);
  }

  body,
  h1,
  h2,
  h3,
  h4,
  p,
  ul,
  ol,
  dl,
  dd,
  figure,
  blockquote {
    margin: 0;
  }

  ul,
  ol {
    padding: 0;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  .page-frame {
    max-width: 880px;
    margin: 36px auto;
    padding: 52px 64px 60px;
    background: var(--paper);
    border: 1px solid rgba(30, 30, 28, 0.14);
  }

  .page-frame > header,
  .page-frame > main {
    width: min(100%, 74ch);
    margin-inline: auto;
  }

  .site-main {
    display: block;
  }

  .site-main,
  .section-block,
  .contact-note {
    scroll-margin-top: 24px;
  }

  .eyebrow {
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
    color: var(--soft-ink);
  }

  .section-block {
    display: block;
    margin-top: 48px;
    padding-top: 20px;
    border-top: 1px solid rgba(37, 42, 51, 0.09);
  }

  .section-head {
    display: grid;
    gap: 4px;
    margin-bottom: 14px;
  }

  .section-title {
    font-size: 15px;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: 0;
  }

  .section-body {
    padding: 0;
  }

  .link-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
  }

  .rule-button {
    display: inline;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--ink);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition:
      color 150ms ease,
      text-decoration-color 150ms ease;
  }

  .rule-button:hover,
  .rule-button:focus-visible {
    background: transparent;
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .rule-button:focus-visible {
    outline: 1px solid currentColor;
    outline-offset: 3px;
  }

  .rule-button.secondary {
    color: var(--muted-ink);
  }

  .rule-button.secondary:hover,
  .rule-button.secondary:focus-visible {
    background: transparent;
    color: var(--accent);
  }

  @media (max-width: 900px) {
    .page-frame {
      margin: 20px;
      padding: 36px 40px 48px;
    }

    .section-title {
      font-size: 17px;
    }
  }

  @media (max-width: 640px) {
    .page-frame {
      margin: 0;
      padding: 24px 18px 30px;
      border: none;
    }

    .section-block {
      margin-top: 34px;
    }
  }
</style>
